</div>
 
<!-- OUTPUT MODAL -->
<div id="output-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:200; align-items:center; justify-content:center; padding:20px;">
  <div style="background:white; border-radius:16px; max-width:700px; width:100%; max-height:90vh; overflow:auto; padding:28px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
      <h2 style="font-family:'Space Grotesk',sans-serif; font-size:20px;">Your automation script is ready</h2>
      <button onclick="closeModal()" style="background:none;border:none;cursor:pointer;font-size:24px;color:var(--text-muted);">×</button>
    </div>
 
    <div class="alert" style="margin-bottom:16px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Save your resume at the path shown below, then run this script in VS Code or any terminal.
    </div>
 
    <div style="margin-bottom:16px;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
        <label style="margin:0; font-weight:600; font-size:14px;">linkedin_autoapply.py</label>
        <button onclick="copyCode()" style="font-size:13px; padding:6px 14px; border:1.5px solid var(--border); border-radius:20px; background:white; cursor:pointer; font-family:Inter,sans-serif;">Copy code</button>
      </div>
      <pre id="code-output" style="background:#1e1e2e; color:#cdd6f4; padding:16px; border-radius:10px; font-size:12px; line-height:1.7; overflow-x:auto; white-space:pre-wrap; font-family:monospace;"></pre>
    </div>
 
    <div style="display:flex; gap:12px; flex-wrap:wrap;">
      <button onclick="downloadScript()" style="flex:1; background:var(--blue); color:white; border:none; padding:13px 20px; border-radius:24px; font-size:15px; font-weight:600; cursor:pointer; font-family:Inter,sans-serif;">⬇ Download script</button>
      <button onclick="closeModal()" style="flex:1; background:white; color:var(--text); border:1.5px solid var(--border); padding:13px 20px; border-radius:24px; font-size:15px; cursor:pointer; font-family:Inter,sans-serif;">Close</button>
    </div>
  </div>
</div>
 
<footer>LinkedAuto is an open-source automation helper. Use responsibly and within LinkedIn's Terms of Service.</footer>
 
<script>
  function toggleChip(el) {
    el.classList.toggle('active');
  }
 
  function toggleSingle(el, selector) {
    document.querySelectorAll(selector).forEach(c => c.classList.remove('active'));
    el.classList.add('active');
  }
 
  function addTagOnEnter(e, wrapId, inpId) {
    if (e.key !== 'Enter') return;
    e.preventDefault();
    const inp = document.getElementById(inpId);
    const val = inp.value.trim();
    if (!val) return;
    const wrap = document.getElementById(wrapId);
    const tag = document.createElement('div');
    tag.className = 'tag';
    tag.innerHTML = `${val}<button onclick="removeTag(this,'${wrapId}')" title="Remove">×</button>`;
    wrap.insertBefore(tag, inp);
    inp.value = '';
  }
 
  function removeTag(btn, wrapId) {
    btn.parentElement.remove();
  }
 
  function handleFile(inp) {
    const file = inp.files[0];
    if (!file) return;
    const fn = document.getElementById('file-name');
    fn.innerHTML = `✅ ${file.name}`;
    fn.style.display = 'flex';
  }
 
  function handleDrag(e) { e.preventDefault(); document.getElementById('dropzone').classList.add('drag-over'); }
  function handleDragLeave() { document.getElementById('dropzone').classList.remove('drag-over'); }
  function handleDrop(e) {
    e.preventDefault();
    document.getElementById('dropzone').classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file) {
      const fi = document.getElementById('resume-file');
      const dt = new DataTransfer();
      dt.items.add(file);
      fi.files = dt.files;
      handleFile(fi);
    }
  }
 
  function getTitles() {
    const tags = document.querySelectorAll('#titles-wrap .tag');
    return Array.from(tags).map(t => t.childNodes[0].textContent.trim()).filter(Boolean);
  }
 
  function getExpLevels() {
    const chips = document.querySelectorAll('.filter-chips .chip.active');
    const map = { 'Internship': 1, 'Entry level': 2, 'Associate': 3, 'Mid-Senior': 4, 'Director': 5 };
    return Array.from(chips).map(c => map[c.textContent.trim()]).filter(Boolean);
  }
 
  function generateScript(config) {
    return `from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager
import time, os, random
 
# ── CONFIG (generated by LinkedAuto) ──────────────────────
LINKEDIN_EMAIL    = "${config.email}"
LINKEDIN_PASSWORD = "${config.password}"
JOB_TITLES        = ${JSON.stringify(config.titles)}
JOB_LOCATION      = "${config.location}"
RESUME_PATH       = r"${config.resumeName ? config.resumeName : '/path/to/your/resume.pdf'}"
PHONE             = "${config.phone}"
MAX_APPLY         = ${config.maxApps}
SLOW_MODE         = ${config.slowMode ? 'True' : 'False'}
# ──────────────────────────────────────────────────────────
 
def delay(a=1, b=3):
    time.sleep(random.uniform(a, b) if SLOW_MODE else 1)
 
def setup_driver():
    opts = webdriver.ChromeOptions()
    opts.add_argument("--start-maximized")
    opts.add_experimental_option("excludeSwitches", ["enable-automation"])
    opts.add_experimental_option("useAutomationExtension", False)
    return webdriver.Chrome(service=Service(ChromeDriverManager().install()), options=opts)
 
def login(driver):
    print("[*] Logging in...")
    driver.get("https://www.linkedin.com/login")
    delay(2, 3)
    driver.find_element(By.ID, "username").send_keys(LINKEDIN_EMAIL)
    driver.find_element(By.ID, "password").send_keys(LINKEDIN_PASSWORD)
    driver.find_element(By.XPATH, "//button[@type='submit']").click()
    delay(3, 5)
    print("[✓] Logged in")
 
def search_jobs(driver, title):
    url = (f"https://www.linkedin.com/jobs/search/"
           f"?keywords={title.replace(' ', '%20')}"
           f"&location=${config.location.replace(' ', '%20')}"
           f"&f_AL=true")
    driver.get(url)
    delay(3, 4)
 
def handle_form(driver, title):
    for step in range(8):
        delay(1.5, 2.5)
        try:
            fi = driver.find_element(By.CSS_SELECTOR, "input[type='file']")
            if os.path.exists(RESUME_PATH):
                fi.send_keys(RESUME_PATH)
                print(f"   [✓] Resume uploaded")
                delay(1, 2)
        except: pass
        try:
            ph = driver.find_element(By.CSS_SELECTOR, "input[id*='phoneNumber']")
            if not ph.get_attribute("value"):
                ph.send_keys(PHONE)
        except: pass
        try:
            driver.find_element(By.CSS_SELECTOR, "button[aria-label='Submit application']").click()
            print(f"   [✓✓] Applied: {title}")
            return True
        except: pass
        try:
            btn = driver.find_element(By.CSS_SELECTOR,
                "button[aria-label='Continue to next step'],"
                "button[aria-label='Review your application'],"
                "button[aria-label='Next']")
            btn.click()
            continue
        except: pass
        try:
            driver.find_element(By.CSS_SELECTOR, "button[aria-label='Dismiss']").click()
            delay()
            driver.find_element(By.CSS_SELECTOR, "button[data-control-name='discard_application_confirm_btn']").click()
        except: pass
        return False
    return False
 
def apply_jobs(driver, title, applied):
    search_jobs(driver, title)
    cards = driver.find_elements(By.CSS_SELECTOR, ".jobs-search__results-list li")
    print(f"[*] Found {len(cards)} listings for '{title}'")
    for i, card in enumerate(cards):
        if applied[0] >= MAX_APPLY: break
        try:
            card.click()
            delay(1.5, 2.5)
            job_title_el = driver.find_element(By.CSS_SELECTOR, ".jobs-unified-top-card__job-title")
            jt = job_title_el.text
        except:
            jt = f"Job #{i+1}"
        try:
            btn = WebDriverWait(driver, 4).until(
                EC.element_to_be_clickable((By.CSS_SELECTOR, ".jobs-apply-button--top-card")))
            btn.click()
            delay(1.5, 2)
            if handle_form(driver, jt):
                applied[0] += 1
        except:
            print(f"   [skip] No Easy Apply: {jt}")
        delay(2, 4)
 
def main():
    driver = setup_driver()
    applied = [0]
    try:
        login(driver)
        for title in JOB_TITLES:
            if applied[0] >= MAX_APPLY: break
            apply_jobs(driver, title, applied)
        print(f"\\n[✓] Done! Applied to {applied[0]} jobs.")
    except KeyboardInterrupt:
        print("\\n[!] Stopped by user")
    finally:
        driver.quit()
 
if __name__ == "__main__":
    main()
`;
  }
 
  let generatedScript = '';
 
  function startAutomation() {
    const email = document.getElementById('li-email').value.trim();
    const password = document.getElementById('li-pass').value.trim();
    const titles = getTitles();
    const location = document.getElementById('li-loc').value.trim();
    const maxApps = parseInt(document.getElementById('max-apps').value);
    const phone = document.getElementById('li-phone').value.trim();
    const slowMode = document.getElementById('opt-slow').checked;
    const fileInput = document.getElementById('resume-file');
    const resumeName = fileInput.files[0] ? fileInput.files[0].name : '';
 
    if (!email || !password) {
      alert('Please enter your LinkedIn email and password.');
      return;
    }
    if (titles.length === 0) {
      alert('Please add at least one job title.');
      return;
    }
 
    const config = { email, password, titles, location, maxApps, phone, slowMode, resumeName };
    generatedScript = generateScript(config);
 
    document.getElementById('code-output').textContent = generatedScript;
    document.getElementById('output-modal').style.display = 'flex';
 
    // Simulate progress in sidebar
    simulateProgress(maxApps);
  }
 
  function simulateProgress(max) {
    const dot = document.getElementById('status-dot');
    const title = document.getElementById('status-title');
    const sub = document.getElementById('status-sub');
    const log = document.getElementById('job-log');
    const fill = document.getElementById('prog-fill');
    const pct = document.getElementById('prog-pct');
    const cntA = document.getElementById('cnt-applied');
    const cntS = document.getElementById('cnt-skipped');
    const cntT = document.getElementById('cnt-total');
 
    dot.className = 'status-dot running';
    title.textContent = 'Automation ready';
    sub.textContent = 'Script generated — run it in VS Code';
    log.innerHTML = '';
 
    const mockJobs = [
      { t: 'Backend Developer — Infosys', s: 'applied' },
      { t: 'Python Engineer — TCS Digital', s: 'applied' },
      { t: 'Node.js Developer — Wipro', s: 'skipped' },
      { t: 'Django Developer — Zoho Corp', s: 'applied' },
      { t: 'API Engineer — Razorpay', s: 'applied' },
      { t: 'Backend Intern — Swiggy Tech', s: 'applied' },
      { t: 'Software Engineer II — PhonePe', s: 'skipped' },
      { t: 'Backend Developer — Freshworks', s: 'applied' },
    ];
 
    let i = 0, applied = 0, skipped = 0;
    const icons = { applied: { emoji: '✅', cls: 'success', badge: 'Applied', badgeCls: 'applied' }, skipped: { emoji: '⏩', cls: 'skip', badge: 'Skipped', badgeCls: 'skipped' } };
 
    const interval = setInterval(() => {
      if (i >= Math.min(mockJobs.length, max)) {
        clearInterval(interval);
        dot.className = 'status-dot done';
        title.textContent = 'Preview complete';
        sub.textContent = 'Run the script to apply for real';
        return;
      }
      const job = mockJobs[i];
      const ic = icons[job.s];
      if (job.s === 'applied') applied++;
      else skipped++;
      i++;
 
      const item = document.createElement('div');
      item.className = 'log-item';
      item.innerHTML = `
        <div class="log-icon ${ic.cls}">${ic.emoji}</div>
        <div class="log-body">
          <div class="log-title">${job.t}</div>
          <div class="log-meta">Just now</div>
        </div>
        <span class="log-badge ${ic.badgeCls}">${ic.badge}</span>
      `;
      log.prepend(item);
 
      cntA.textContent = applied;
      cntS.textContent = skipped;
      cntT.textContent = i;
      const p = Math.round((i / Math.min(mockJobs.length, max)) * 100);
      fill.style.width = p + '%';
      pct.textContent = p + '%';
    }, 900);
  }
 
  function closeModal() {
    document.getElementById('output-modal').style.display = 'none';
  }
 
  function copyCode() {
    navigator.clipboard.writeText(generatedScript).then(() => {
      const btn = event.target;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy code', 2000);
    });
  }
 
  function downloadScript() {
    const blob = new Blob([generatedScript], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'linkedin_autoapply.py';
    a.click();
  }
</script>
