      <!-- START BUTTON -->
      <button class="start-btn" id="start-btn" onclick="startAutomation()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Generate & run automation script
      </button>
 
    </div>
  </div>
 
  <!-- SIDEBAR -->
  <div class="sidebar">
 
    <!-- STATUS PANEL -->
    <div class="card status-panel">
      <div class="status-header">
        <div class="status-dot" id="status-dot"></div>
        <div>
          <div class="status-title" id="status-title">Ready to start</div>
          <div class="status-sub" id="status-sub">Configure your settings and click run</div>
        </div>
      </div>
 
      <div class="summary-chips">
        <div class="summary-chip"><div class="n n-applied" id="cnt-applied">0</div><div class="l">Applied</div></div>
        <div class="summary-chip"><div class="n n-skipped" id="cnt-skipped">0</div><div class="l">Skipped</div></div>
        <div class="summary-chip"><div class="n n-total" id="cnt-total">0</div><div class="l">Scanned</div></div>
      </div>
 
      <div class="progress-wrap">
        <div class="progress-label">
          <span id="prog-label">Progress</span>
          <span id="prog-pct">0%</span>
        </div>
        <div class="progress-track"><div class="progress-fill" id="prog-fill" style="width:0%"></div></div>
      </div>
 
      <div class="job-log" id="job-log">
        <div style="text-align:center; padding: 24px 0; color:var(--text-hint); font-size:13px;">Applications will appear here</div>
      </div>
    </div>
 
    <!-- HOW IT WORKS -->
    <div class="card" id="howto" style="margin-top:20px;">
      <h2 style="margin-bottom:8px;">
        <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></span>
        How it works
      </h2>
      <div class="steps" style="margin-top:16px;">
        <div class="step-item">
          <div class="step-num">1</div>
          <div class="step-text"><h4>Fill in your details</h4><p>Enter your LinkedIn credentials and target role</p></div>
        </div>
        <div class="step-item">
          <div class="step-num">2</div>
          <div class="step-text"><h4>Upload your resume</h4><p>One PDF or Word file — reused on every application</p></div>
        </div>
        <div class="step-item">
          <div class="step-num">3</div>
          <div class="step-text"><h4>Click run</h4><p>Downloads a Python script pre-filled with your config</p></div>
